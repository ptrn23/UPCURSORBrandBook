=== Correct vs. Incorrect Usage
#v(1em)

#grid(
  columns: (1fr, 1fr, 1fr),
  gutter: 2em,
  row-gutter: 3em,

  // 1. Stretching
  type-rule(
    pass: false,
    title: "Don't stretch or distort",
    desc: "Never stretch, condense, or skew the logo horizontally or vertically. Always scale proportionally.",
    visual: [
      // Typst physically stretches the SVG here!
      #scale(x: 140%)[#image("images/logos/UPCURSOR_HorizontalLogo_CURSORGreen_Transparent.svg", width: 70%)]
    ]
  ),
  
  // 2. Rotating
  type-rule(
    pass: false,
    title: "Don't rotate",
    desc: "Do not rotate the logo to any degree. It must always sit perfectly horizontal on the baseline.",
    visual: [
      // Typst physically rotates the SVG!
      #rotate(-15deg)[#image("images/logos/UPCURSOR_HorizontalLogo_CURSORGreen_Transparent.svg", width: 80%)]
    ]
  ),
  
  // 3. Drop Shadows
  type-rule(
    pass: false,
    title: "Don't add effects",
    desc: "Avoid using drop shadows, glows, bevels, or any other artificial layer effects that muddy the design.",
    visual: [
       // Simulating a drop shadow by placing the Black logo offset behind the Green logo!
       #image("images/logos/UPCURSOR_HorizontalLogo_CURSORGreen_Transparent.svg", width: 80%)
       #place(dx: 24pt, dy: -24pt)[#image("images/logos/UPCURSOR_HorizontalLogo_CURSORBlack_Transparent.svg", width: 80%)]
    ]
  ),

  // 4. Rearranging
  type-rule(
    pass: false,
    title: "Don't rearrange elements",
    desc: "Do not move the cursor mark to the right side, stack the horizontal text, or alter the designated 'U' gap.",
    visual: [
      // Faking a bad arrangement by using text and the icon!
      #align(center)[
        #text(font: font-title, size: 24pt, weight: "bold", fill: cursor-green)[UP CURSOR]
        #v(-4em)
        #image("images/logos/UPCURSOR_MainLogo_CURSORGreen_Transparent.svg", height: 15mm)
      ]
    ]
  ),
  
  // 5. Wrong Colors
  type-rule(
    pass: false,
    title: "Don't use unapproved colors",
    desc: "Never apply custom gradients, outlines, or unapproved colors to the logo. Stick to the official variants.",
    visual: [
      // Typst trick: Tints the black logo red by laying a colored rectangle over it using "lighten" blend mode, or you can just swap this for a bad export!
      #text(font: font-title, size: 24pt, weight: "bold", fill: rgb("#D93838"))[UP CURSOR]
    ]
  ),
  
  // 6. Busy Backgrounds
  type-rule(
    pass: false,
    title: "Don't place on busy backgrounds",
